{
  "name": "officekit-workspace",
  "private": true,
  "version": "0.1.0",
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "officekit": "bun run packages/cli/bin/officekit",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "bun test",
    "lint": "tsc --noEmit -p tsconfig.json",
    "verify": "bun run typecheck && bun test"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "bun-types": "^1.3.11",
    "typescript": "^5.9.2"
  }
}
